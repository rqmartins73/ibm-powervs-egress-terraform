#!/bin/bash
#
# Push Repo to GitHub
#########################################
description=$1
if [[ $# -ne 1 ]]; then
	echo "ERROR: Wrong syntax." >&2
	echo "Usage: $(basename "$0") \"Description...\"" >&2
	exit 1
fi
ls -la
find . -name "*Zone.Identifier*" -delete
ls -la
read -p "Ready to go? <ENTER>"
git init
git add .
git status
git commit -m "$description"
git branch -M main
git push -u origin main
